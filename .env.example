PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sky_pulse
POSTGRES_PORT=5433

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/sky_pulse
JWT_ISSUER=air-quality-api
JWT_AUDIENCE=air-quality-clients
JWKS_URL=http://localhost:3002/api/v1/.well-known/jwks.json
JWKS_URL_DOCKER=http://host.docker.internal:3002/api/v1/.well-known/jwks.json

# Ingest Open-Meteo đã chuyển sang air-quality-api.
# Xem air-quality-api/.env.example: INGEST_ENABLED, INGEST_CRON, OPENMETEO_PAST_HOURS.

# ----- Analytics & ML -----
ANALYTICS_ENABLED=true
ANALYTICS_SUMMARY_CRON=0 1 * * *
ANALYTICS_ANOMALY_CRON=0 */2 * * *
ANALYTICS_FORECAST_CRON=0 2 * * *
